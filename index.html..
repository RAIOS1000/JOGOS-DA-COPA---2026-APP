// ═══════════════════════════════════════
//  RENDER — GRUPOS
// ═══════════════════════════════════════
function renderGrupos(){
  const el=document.getElementById('gg');
  el.innerHTML=D.grupos.map(g=>{
    const sorted=[...g.tab].sort((a,b)=>{
      if(b.pts!==a.pts)return b.pts-a.pts;
      const dif=(x)=>x.gp-x.gc;
      if(dif(b)!==dif(a))return dif(b)-dif(a);
      return b.gp-a.gp;
    });
    const rows=sorted.map((t,i)=>{
      const sg=t.gp-t.gc;
      const qc=i<2?'q':'';
      const br=t.t==='Brasil'?'brow':'';
      return `<tr class="${br}"><td>
        <div class="tc"><span class="pn ${qc}">${i+1}</span>
        <span class="fl">${t.f}</span><span class="tn" onclick="openTeam('${t.t.replace(/'/g,"")}')">${t.t}</span></div>
      </td>
        <td class="pts">${t.pts}</td>
        <td>${t.j}</td><td>${t.v}</td><td>${t.e}</td><td>${t.d}</td>
        <td>${t.gp}</td><td>${t.gc}</td>
        <td class="${sgc(sg)}">${sgs(sg)}</td>
      </tr>`;
    }).join('');

    const games=g.res.map(r=>{
      let sc=r.sc||'×';
      let sc_cls='ft';
      let row_cls='';
      if(r.st==='fim'){sc_cls='fim';row_cls='fim';}
      else if(r.st==='hj'||r.st==='hoje'||r.st==='today'){sc_cls='hj';row_cls='hj';}
      else if(r.st==='lv'||r.st==='live'){sc='🔴 AO VIVO';sc_cls='lv';row_cls='hj';}
      return `<div class="jr ${row_cls}">
        <span class="jdt">${r.dt}</span>
        <span class="jtm">${r.fm} ${r.m}</span>
        <span class="jsc ${sc_cls}">${sc}</span>
        <span class="jtm r">${r.v} ${r.fv}</span>
      </div>`;
    }).join('');

    const estrela=g.brasil?'<span style="font-size:11px;margin-left:6px">⭐ BRASIL</span>':'';
    return `<div class="gc ${g.brasil?'br':''}">
      <div class="gh">
        <span class="gl">GRUPO ${g.letra}${estrela}</span>
        <span class="gn">${sorted.map(t=>t.t).join('<br>')}</span>
      </div>
      <table class="tab">
        <thead><tr>
          <th>TIME</th><th>PTS</th><th>J</th><th>V</th><th>E</th><th>D</th><th>GP</th><th>GC</th><th>SG</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
      <div class="res">
        <div class="rlbl">Jogos</div>
        ${games}
      </div>
    </div>`;
  }).join('');
}

