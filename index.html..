<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⚽ Copa do Mundo 2026 — Tabela ao Vivo</title>
<meta name="description" content="Tabela interativa da Copa do Mundo 2026: grupos, artilheiros, calendário com sedes, elencos, gols e acompanhamento em tempo real. Atualizada diariamente.">
<meta name="author" content="raios1000">
<meta name="theme-color" content="#060A18">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Copa 2026">
<!-- Open Graph (compartilhamento WhatsApp/redes) -->
<meta property="og:type" content="website">
<meta property="og:title" content="⚽ Copa do Mundo 2026 — Tabela ao Vivo">
<meta property="og:description" content="Grupos, artilheiros, calendário com estádios, elencos por time e acompanhamento em tempo real.">
<meta property="og:locale" content="pt_BR">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="⚽ Copa do Mundo 2026 — Tabela ao Vivo">
<meta name="twitter:description" content="Grupos, artilheiros, calendário, elencos e tempo real.">
<!-- Favicon emoji (sem arquivo externo) -->
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏆</text></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#060A18;--card:#0D1226;--border:#1C2640;
  --gold:#D4AF37;--gold2:#F0D060;--gdim:rgba(212,175,55,.12);
  --green:#27AE60;--red:#E74C3C;
  --text:#E8ECF5;--dim:#5A6A8A;--dim2:#8B9DC3;
  --fh:'Bebas Neue',sans-serif;--fb:'Inter',sans-serif;--fn:'Oswald',sans-serif;
}
body{background:var(--bg);color:var(--text);font-family:var(--fb);min-height:100vh;overflow-x:hidden}

/* HEADER */
.hdr{background:linear-gradient(180deg,#050816,#09102A);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
.htop{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;background:linear-gradient(135deg,#04071A,#0B1535 50%,#04071A)}
.brand{display:flex;align-items:center;gap:10px}
.trophy{font-size:26px;animation:glow 3s ease-in-out infinite alternate;filter:drop-shadow(0 0 6px rgba(212,175,55,.5))}
@keyframes glow{from{filter:drop-shadow(0 0 4px rgba(212,175,55,.3))}to{filter:drop-shadow(0 0 14px rgba(212,175,55,.95))}}
.btxt h1{font-family:var(--fh);font-size:20px;letter-spacing:3px;color:var(--gold);line-height:1}
.btxt p{font-size:9px;color:var(--dim);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.hmeta{text-align:right}
.badge{background:var(--gold);color:#000;font-family:var(--fh);font-size:11px;letter-spacing:1px;padding:3px 9px;border-radius:3px;display:inline-block;margin-bottom:3px}
.upd{font-size:9px;color:var(--dim);letter-spacing:1px}

/* TICKER */
.tickwrap{background:var(--gold);overflow:hidden;height:26px;display:flex;align-items:center;cursor:pointer}
.tickin{display:flex;white-space:nowrap;animation:sticker 60s linear infinite}
.tickwrap:hover .tickin{animation-play-state:paused}
.tk{display:inline-flex;align-items:center;gap:6px;padding:0 28px;font-size:11px;font-weight:700;color:#000;font-family:var(--fn);letter-spacing:.5px}
@keyframes sticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* NAV */
.nav{display:flex;background:var(--card);border-bottom:2px solid var(--border)}
.nb{flex:1;background:none;border:none;color:var(--dim);font-family:var(--fh);font-size:13px;letter-spacing:2px;padding:13px 4px;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;transition:all .2s}
.nb.on{color:var(--gold);border-bottom-color:var(--gold)}
.nb:hover:not(.on){color:var(--text);background:var(--gdim)}

/* LAYOUT */
.main{padding:14px;max-width:1280px;margin:0 auto}
.sec{display:none}.sec.on{display:block}

/* GROUPS */
.gg{display:grid;grid-template-columns:repeat(auto-fill,minmax(330px,1fr));gap:14px}
.gc{background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.gc.br{border-color:rgba(0,156,59,.5);box-shadow:0 0 20px rgba(0,156,59,.1)}
.gh{background:linear-gradient(135deg,#0A1128,#131D3A);padding:10px 14px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}
.gl{font-family:var(--fh);font-size:22px;color:var(--gold);letter-spacing:1px}
.gn{font-size:8px;color:var(--dim);letter-spacing:1px;text-transform:uppercase;text-align:right;line-height:1.5}

/* TABLE */
.tab{width:100%;border-collapse:collapse;font-size:12px}
.tab thead tr{background:rgba(255,255,255,.025)}
.tab th{padding:5px 6px;text-align:center;font-size:8px;color:var(--dim);letter-spacing:1px;font-weight:600;text-transform:uppercase}
.tab th:first-child{text-align:left;padding-left:10px;width:44%}
.tab td{padding:6px 6px;text-align:center;border-top:1px solid rgba(255,255,255,.035);font-family:var(--fn);font-size:13px}
.tab td:first-child{text-align:left;padding-left:10px}
.pts{font-weight:700;color:var(--gold)}
.sgp{color:var(--green)}.sgn{color:var(--red)}.sgz{color:var(--dim)}
.tc{display:flex;align-items:center;gap:5px}
.pn{width:14px;font-size:9px;color:var(--dim);font-family:var(--fn)}
.pn.q{color:var(--green)}
.fl{font-size:15px;line-height:1}
.tn{font-family:var(--fb);font-size:11px;font-weight:500;color:var(--text);white-space:nowrap}
.brow td{background:rgba(0,156,59,.07)}

/* RESULTS */
.res{border-top:1px solid var(--border);padding:8px 8px 4px}
.rlbl{font-size:8px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;padding:0 2px 6px;font-weight:600}
.jr{display:grid;grid-template-columns:40px 1fr 52px 1fr;align-items:center;gap:4px;padding:4px 2px;border-radius:5px}
.jr.fim{background:rgba(255,255,255,.025)}
.jr.hj{background:rgba(212,175,55,.08)}
.jdt{font-size:8px;color:var(--dim);font-family:var(--fn);text-align:center}
.jtm{display:flex;align-items:center;gap:4px;font-size:10px;font-weight:500}
.jtm.r{justify-content:flex-end}
.jsc{background:rgba(255,255,255,.07);border-radius:4px;padding:2px 6px;font-family:var(--fh);font-size:14px;color:var(--text);text-align:center;min-width:44px}
.jsc.fim{background:rgba(39,174,96,.15);color:#2ECC71}
.jsc.hj{background:rgba(212,175,55,.2);color:var(--gold)}
.jsc.lv{background:rgba(231,76,60,.25);color:#FF6B5A;animation:blink .9s ease-in-out infinite}
.jsc.ft{color:var(--dim);font-size:12px}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}

/* LEGEND */
.leg{display:flex;gap:16px;padding:8px 12px;font-size:9px;color:var(--dim);border-top:1px solid var(--border)}
.leg span{display:flex;align-items:center;gap:4px}
.dot{width:6px;height:6px;border-radius:50%}
.dot.g{background:var(--green)}.dot.y{background:#F39C12}

/* ARTILHEIROS */
.ahero{background:linear-gradient(135deg,#0A1128,#141D3A);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:16px;text-align:center}
.ahero h2{font-family:var(--fh);font-size:34px;color:var(--gold);letter-spacing:4px;margin-bottom:4px}
.ahero p{font-size:10px;color:var(--dim);letter-spacing:2px;text-transform:uppercase}
.ahero .sub{font-size:11px;color:var(--dim2);margin-top:10px;line-height:1.6}
.ahero .sub em{color:var(--gold2);font-style:normal;font-weight:700}

.facts{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px;margin-bottom:16px}
.fact{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:12px 14px;display:flex;align-items:flex-start;gap:10px}
.fi{font-size:22px;flex-shrink:0;margin-top:1px}
.ft{font-size:11px;color:var(--dim2);line-height:1.5}
.ft strong{color:var(--text);display:block;font-size:12px;margin-bottom:2px}

.pod3{display:grid;grid-template-columns:1fr 1.15fr 1fr;gap:10px;margin-bottom:16px}
.pc{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px 10px;text-align:center}
.pc.p1{border-color:var(--gold);background:linear-gradient(180deg,rgba(212,175,55,.14),var(--card) 60%)}
.pc.p2{margin-top:20px;border-color:rgba(192,192,192,.25)}
.pc.p3{margin-top:36px;border-color:rgba(205,127,50,.25)}
.pm{font-size:22px;margin-bottom:4px}
.pf{font-size:30px;margin:5px 0}
.pn{font-size:12px;font-weight:700;color:var(--text)}
.ps{font-size:9px;color:var(--dim);margin-bottom:8px;letter-spacing:1px}
.pg{font-family:var(--fh);font-size:40px;color:var(--gold);line-height:1}
.pl{font-size:8px;color:var(--dim);letter-spacing:2px;text-transform:uppercase}

.atbl{background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.atbl table{width:100%;border-collapse:collapse}
.atbl thead tr{background:rgba(212,175,55,.08)}
.atbl th{padding:9px 12px;text-align:left;font-size:8px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;font-weight:600}
.atbl th.c,.atbl td.c{text-align:center}
.atbl td{padding:9px 12px;border-top:1px solid rgba(255,255,255,.035);font-size:13px;vertical-align:middle}
.ap{font-family:var(--fn);color:var(--dim);font-size:12px}
.apd{display:flex;align-items:center;gap:8px}
.af{font-size:19px}
.ai .an{font-weight:600;font-size:12px}
.ai .as{font-size:9px;color:var(--dim);letter-spacing:.5px}
.ag{font-family:var(--fh);font-size:22px;color:var(--gold)}
.aj{font-family:var(--fn);color:var(--dim);font-size:13px}
.atbl tbody tr:hover td{background:rgba(255,255,255,.02)}

/* CALENDAR */
.cday{margin-bottom:24px}
.cdh{display:flex;align-items:center;gap:12px;margin-bottom:10px;flex-wrap:wrap}
.cdt{background:var(--gold);color:#000;font-family:var(--fh);font-size:15px;padding:4px 13px;border-radius:5px;letter-spacing:1px}
.cdt.hoje{background:#C0392B;color:#fff}
.cdw{font-size:10px;color:var(--dim);letter-spacing:2px;text-transform:uppercase}
.clive{font-size:10px;color:#C0392B;font-weight:700;letter-spacing:1px;animation:blink .9s ease-in-out infinite}
.cgames{display:flex;flex-direction:column;gap:7px}
.cj{background:var(--card);border:1px solid var(--border);border-radius:7px;padding:11px 14px;display:grid;grid-template-columns:52px 1fr 66px 1fr 52px;align-items:center;gap:8px}
.cj.cfim{border-color:rgba(39,174,96,.25)}
.cj.chj{border-color:rgba(212,175,55,.4);background:rgba(212,175,55,.04)}
.cj.clv{border-color:rgba(231,76,60,.5);background:rgba(231,76,60,.05)}
.cg{font-size:8px;letter-spacing:1px;color:var(--dim);background:rgba(255,255,255,.06);padding:2px 6px;border-radius:3px;text-align:center;font-family:var(--fn)}
.ctm{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:500}
.ctm.r{justify-content:flex-end}
.csc{text-align:center;font-family:var(--fh);font-size:20px;letter-spacing:1px;white-space:nowrap}
.csc.cfim{color:#2ECC71}.csc.cft{color:var(--dim);font-size:14px}
.csc.chj{color:var(--gold)}.csc.clv{color:#FF6B5A;animation:blink .9s ease-in-out infinite}
.chr{text-align:center;font-size:9px;color:var(--dim);font-family:var(--fn)}

/* FOOTER */
.footer{text-align:center;padding:24px 16px;color:var(--dim);font-size:10px;border-top:1px solid var(--border);margin-top:32px;letter-spacing:.5px;line-height:1.8}



/* STATUS API */
.apibar{display:flex;align-items:center;gap:7px;justify-content:flex-end;margin-top:5px;flex-wrap:wrap}
.apistat{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-family:var(--fn);letter-spacing:.5px;padding:2px 8px;border-radius:20px;border:1px solid var(--border)}
.apistat .d{width:7px;height:7px;border-radius:50%}
.apistat.ok{color:#2ECC71;border-color:rgba(39,174,96,.4)}
.apistat.ok .d{background:#2ECC71;box-shadow:0 0 6px #2ECC71;animation:blink 1.6s infinite}
.apistat.warn{color:#F0C040;border-color:rgba(240,192,64,.4)}
.apistat.warn .d{background:#F0C040}
.apistat.load{color:var(--dim2)}
.apistat.load .d{background:var(--dim2);animation:blink .8s infinite}
.refbtn{background:var(--gold-dim,rgba(212,175,55,.12));border:1px solid rgba(212,175,55,.4);color:var(--gold);font-size:10px;font-family:var(--fn);letter-spacing:.5px;padding:3px 9px;border-radius:20px;cursor:pointer;display:inline-flex;align-items:center;gap:4px}
.refbtn:hover{background:rgba(212,175,55,.25)}
.refbtn:disabled{opacity:.5;cursor:wait}

/* RELÓGIO + PAINEL AO VIVO */
.clock{display:flex;align-items:center;gap:6px;justify-content:flex-end;margin-top:4px}
.clock .dotlive{width:7px;height:7px;border-radius:50%;background:#2ECC71;box-shadow:0 0 6px #2ECC71;animation:blink 1.4s ease-in-out infinite}
.clock span{font-family:var(--fn);font-size:11px;color:var(--dim2);letter-spacing:1px}
.lp{margin:0 0 16px;border-radius:12px;overflow:hidden;border:1px solid var(--border);background:linear-gradient(135deg,#0A1128,#0E1733)}
.lp-h{display:flex;align-items:center;gap:8px;padding:9px 14px;background:rgba(255,255,255,.03);border-bottom:1px solid var(--border)}
.lp-h .pulse{width:9px;height:9px;border-radius:50%;background:#E74C3C;box-shadow:0 0 8px #E74C3C;animation:blink .9s infinite}
.lp-h .pulse.idle{background:var(--gold);box-shadow:0 0 8px var(--gold);animation:none}
.lp-h b{font-family:var(--fh);font-size:14px;letter-spacing:2px;color:var(--text)}
.lp-body{padding:12px 14px}
.lp-empty{font-size:12px;color:var(--dim);text-align:center;padding:6px}
.lpm{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:10px;padding:8px 0}
.lpm+.lpm{border-top:1px solid rgba(255,255,255,.04)}
.lpm .side{display:flex;align-items:center;gap:7px;font-size:13px;font-weight:600}
.lpm .side.r{justify-content:flex-end}
.lpm .side .fl{font-size:22px}
.lpm .mid{text-align:center;min-width:80px}
.lpm .mid .vs{font-family:var(--fh);font-size:18px;color:#FF6B5A;letter-spacing:1px}
.lpm .mid .min{font-size:9px;color:#FF6B5A;letter-spacing:1px;animation:blink 1s infinite}
.lpm .mid .ko{font-family:var(--fh);font-size:16px;color:var(--gold)}
.lpm .mid .cd{font-size:9px;color:var(--dim2);letter-spacing:1px;font-family:var(--fn)}
.lpm .mid .grp{font-size:8px;color:var(--dim);letter-spacing:1px;margin-top:2px}
.cdbig{font-family:var(--fn);font-size:15px;color:var(--gold);letter-spacing:1px}


/* MODAL TIME */
.tn{cursor:pointer;border-bottom:1px dotted transparent;transition:border .15s}
.tc:hover .tn{border-bottom-color:var(--gold);color:var(--gold2)}
.ovl{position:fixed;inset:0;background:rgba(2,4,12,.86);backdrop-filter:blur(4px);z-index:1000;display:none;align-items:flex-start;justify-content:center;padding:20px 12px;overflow-y:auto}
.ovl.on{display:flex}
.modal{background:var(--card);border:1px solid var(--border);border-radius:14px;max-width:560px;width:100%;overflow:hidden;animation:pop .25s ease}
@keyframes pop{from{transform:translateY(12px) scale(.98);opacity:0}to{transform:none;opacity:1}}
.m-hd{position:relative;padding:22px 20px 18px;background:linear-gradient(135deg,#0A1128,#15224A);border-bottom:1px solid var(--border)}
.m-x{position:absolute;top:12px;right:14px;background:rgba(255,255,255,.08);border:none;color:var(--text);width:30px;height:30px;border-radius:50%;font-size:16px;cursor:pointer;line-height:1}
.m-x:hover{background:rgba(231,76,60,.4)}
.m-flag{font-size:50px;line-height:1}
.m-name{font-family:var(--fh);font-size:30px;letter-spacing:2px;color:var(--text);margin-top:6px}
.m-sub{font-size:11px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.m-bd{padding:16px 20px 22px;max-height:62vh;overflow-y:auto}
.triv{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
.tcard{background:var(--card2,#111829);border:1px solid var(--border);border-radius:8px;padding:9px 11px}
.tcard .k{font-size:8px;color:var(--dim);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:3px}
.tcard .v{font-size:13px;color:var(--text);font-weight:600}
.tcard .v.live{color:var(--gold);font-family:var(--fn)}
.lead{display:flex;gap:8px;margin-bottom:16px}
.lead .lc{flex:1;background:linear-gradient(135deg,rgba(212,175,55,.1),transparent);border:1px solid rgba(212,175,55,.25);border-radius:8px;padding:9px 11px}
.lead .lc .k{font-size:8px;color:var(--gold);letter-spacing:1.5px;text-transform:uppercase}
.lead .lc .v{font-size:13px;color:var(--text);font-weight:700;margin-top:2px}
.sq h4{font-size:9px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin:12px 0 6px;border-bottom:1px solid var(--border);padding-bottom:4px}
.sq ul{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:3px 12px}
.sq li{font-size:11.5px;color:var(--dim2);padding:2px 0;display:flex;align-items:center;gap:5px}
.sq li::before{content:"•";color:var(--gold);font-size:9px}
.sq li.cap{color:var(--gold2);font-weight:700}
.noel{font-size:11px;color:var(--dim);text-align:center;padding:14px;background:rgba(255,255,255,.02);border-radius:8px;border:1px dashed var(--border)}
/* botão gols / highlights */
.golbtn{display:inline-flex;align-items:center;gap:5px;background:rgba(231,76,60,.16);border:1px solid rgba(231,76,60,.4);color:#FF8A7A;font-size:9px;font-weight:700;letter-spacing:.5px;padding:3px 8px;border-radius:5px;cursor:pointer;text-decoration:none;font-family:var(--fb)}
.golbtn:hover{background:rgba(231,76,60,.3)}
.gollist{margin-top:5px;padding:7px 9px;background:rgba(255,255,255,.03);border-radius:6px;border-left:2px solid var(--gold)}
.gollist .gi{font-size:10px;color:var(--dim2);padding:2px 0;font-family:var(--fn)}
.cj{align-items:center}
.cal-venue{grid-column:1/-1;margin-top:6px;font-size:9.5px;color:var(--dim2);display:flex;align-items:center;gap:5px;letter-spacing:.3px}
.cal-venue .pin{color:var(--gold)}
.cal-venue .vsta{color:var(--text);font-weight:600}
.cal-extra{grid-column:1/-1;margin-top:6px;display:flex;flex-direction:column;gap:5px}

::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

@media(max-width:640px){
  .htop{flex-direction:column;gap:8px;text-align:center}
  .hmeta{text-align:center}
  .pod3{grid-template-columns:repeat(3,1fr)}
  .pc.p2,.pc.p3{margin-top:0}.pg{font-size:30px}
  .gg{grid-template-columns:1fr}
  .cj{grid-template-columns:1fr 58px 1fr;grid-template-rows:auto auto}
  .cg,.chr{display:none}
  .facts{grid-template-columns:1fr}
}
@media(max-width:380px){
  .btxt h1{font-size:15px;letter-spacing:2px}
  .nb{font-size:11px;padding:11px 2px}
}
</style>
</head>
<body>

<header class="hdr">
  <div class="htop">
    <div class="brand">
      <span class="trophy">🏆</span>
      <div class="btxt">
        <h1>Copa do Mundo 2026</h1>
        <p>EUA · Canadá · México — 11 Jun a 19 Jul</p>
      </div>
    </div>
    <div class="hmeta">
      <div class="badge">⚽ DIA 8 · 2ª RODADA</div>
      <div class="clock"><span class="dotlive"></span><span id="clock">--:--:--</span></div>
      <div class="apibar">
        <span class="apistat load" id="apistat"><span class="d"></span><span id="apistat-tx">conectando…</span></span>
        <button class="refbtn" id="refbtn" onclick="syncLive(true)">🔄 Atualizar</button>
      </div>
    </div>
  </div>
  <div class="tickwrap"><div class="tickin" id="tick"></div></div>
