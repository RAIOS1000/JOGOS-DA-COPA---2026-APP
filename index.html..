// aplica um placar vindo da API ao dataset (calendário + grupos)
function applyScore(homePT, awayPT, hs, as_, statusKind, minute){
  const score = (hs!=null && as_!=null) ? `${hs}–${as_}` : '';
  let touched=false;
  function upd(obj){
    if(obj.m===homePT && obj.v===awayPT){
      if(score) obj.sc=score;
      obj._live = (statusKind==='live');
      if(statusKind==='fim') obj.st='fim';
      else if(statusKind==='live'){obj.st='lv'; obj._min=minute||'';}
      touched=true;
    }
  }
  D.calendario.forEach(d=>d.j.forEach(upd));
  D.grupos.forEach(g=>g.res.forEach(upd));
  return touched;
}

async function fetchTheSportsDB(){
  const today=new Date().toISOString().slice(0,10);
  const url=`https://www.thesportsdb.com/api/v1/json/${API.tsdbKey}/eventsday.php?d=${today}&s=Soccer`;
  const r=await fetch(url);
  if(!r.ok) throw new Error('HTTP '+r.status);
  const data=await r.json();
  const evs=(data && data.events)||[];
  let n=0;
  evs.forEach(ev=>{
    const lg=(ev.strLeague||'');
    if(!/world cup/i.test(lg)) return;             // só Copa do Mundo
    const home=pt(ev.strHomeTeam), away=pt(ev.strAwayTeam);
    const hs=ev.intHomeScore, as_=ev.intAwayScore;
    const st=(ev.strStatus||ev.strProgress||'').toString();
    let kind='fut';
    if(/finished|ft|aet|full/i.test(st)) kind='fim';
    else if(/not started|ns|^$/i.test(st)) kind='fut';
    else kind='live';
    if(applyScore(home,away, hs!=null&&hs!==''?hs:null, as_!=null&&as_!==''?as_:null, kind, st)) n++;
  });
  return n;
}

async function fetchWC2026(){
  const r=await fetch('https://api.wc2026api.com/matches', {headers:{'Authorization':'Bearer '+API.wc2026Key}});
  if(!r.ok) throw new Error('HTTP '+r.status);
  const arr=await r.json();
  const list=Array.isArray(arr)?arr:(arr.matches||arr.data||[]);
  let n=0;
  list.forEach(m=>{
    const home=pt(m.home_team), away=pt(m.away_team);
    const ph=(m.phase||m.status||'').toString().toUpperCase();
    let kind='fut';
    if(/FT|FINISH/.test(ph)) kind='fim';
    else if(/1H|2H|HT|ET|PEN|LIVE/.test(ph)) kind='live';
    const hs=m.home_score, as_=m.away_score;
    if(applyScore(home,away, (hs??null), (as_??null), kind, ph)) n++;
  });
  return n;
}

let _syncing=false;
async function syncLive(manual){
  if(!API.enabled || _syncing) return;
  _syncing=true;
  const btn=document.getElementById('refbtn'); if(btn) btn.disabled=true;
  setApiStatus('load', manual?'atualizando…':'conectando…');
  try{
    const n = API.provider==='wc2026' ? await fetchWC2026() : await fetchTheSportsDB();
    const hh=new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
    if(n>0){
      setApiStatus('ok', `API conectada · ${hh}`);
    } else {
      setApiStatus('ok', `conectado · sem jogos hoje · ${hh}`);
    }
    // re-render tudo com os novos placares
    renderGrupos(); renderCalendario(); renderLivePanel(); renderTicker();
  }catch(e){
    setApiStatus('warn', 'dados salvos (API off)');
  }finally{
    _syncing=false;
    if(btn) btn.disabled=false;
  }
}

