// ═══════════════════════════════════════
//  MOTOR DE TEMPO REAL
// ═══════════════════════════════════════
const MATCH_MS = 115*60*1000; // janela "ao vivo" ~1h55

// achata todos os jogos do calendário que tem dt
function allMatches(){
  const out=[];
  D.calendario.forEach(d=>d.j.forEach(j=>{ if(j.dt) out.push(j); }));
  return out.sort((a,b)=>new Date(a.dt)-new Date(b.dt));
}
// status dinâmico baseado no relógio (sobrepõe quando não há placar final salvo)
function liveStatus(j){
  if(j._live) return 'live';                              // API diz que está rolando
  if(!j.dt) return j.st;
  const ko=new Date(j.dt).getTime(), now=Date.now();
  if(j.sc && j.sc!=='×' && j.sc!=='') return 'fim';      // placar final
  if(now < ko) return 'fut';
  if(now < ko+MATCH_MS) return 'live';                    // dentro da janela
  return 'wait';
}
function elapsedMin(j){
  const ko=new Date(j.dt).getTime();
  return Math.max(1,Math.min(90,Math.floor((Date.now()-ko)/60000)));
}
function fmtCountdown(ms){
  if(ms<0) ms=0;
  const h=Math.floor(ms/3600000), m=Math.floor(ms%3600000/60000), s=Math.floor(ms%60000/1000);
  if(h>0) return `${h}h ${String(m).padStart(2,'0')}min`;
  return `${m}min ${String(s).padStart(2,'0')}s`;
}
function fmtHora(dt){
  const d=new Date(dt);
  return String(d.getHours()).padStart(2,'0')+'h'+String(d.getMinutes()).padStart(2,'0');
}

function renderLivePanel(){
  const all=allMatches();
  const live=all.filter(j=>liveStatus(j)==='live');
  const pulse=document.getElementById('lp-pulse');
  const title=document.getElementById('lp-title');
  const body=document.getElementById('lp-body');

  if(live.length){
    pulse.className='pulse';
    title.textContent='🔴 AO VIVO AGORA';
    body.innerHTML=live.map(j=>`
      <div class="lpm">
        <div class="side"><span class="fl">${j.fm}</span>${j.m}</div>
        <div class="mid">
          <div class="vs">${j.sc&&j.sc!=='×'?j.sc:'× ao vivo'}</div>
          <div class="min">⏱ ${elapsedMin(j)}'</div>
          <div class="grp">${j.g}</div>
          ${getVenue(j)?`<div class="grp">📍 ${getVenue(j).c} ${getVenue(j).f}</div>`:''}
        </div>
        <div class="side r">${j.v}<span class="fl">${j.fv}</span></div>
      </div>`).join('');
    return;
  }
  // nenhum ao vivo -> próximo jogo
  const next=all.find(j=>liveStatus(j)==='fut');
  pulse.className='pulse idle';
  if(next){
    const ms=new Date(next.dt).getTime()-Date.now();
    title.textContent='⏳ PRÓXIMO JOGO';
    body.innerHTML=`
      <div class="lpm">
        <div class="side"><span class="fl">${next.fm}</span>${next.m}</div>
        <div class="mid">
          <div class="ko">${fmtHora(next.dt)}</div>
          <div class="cd cdbig" id="cd">${fmtCountdown(ms)}</div>
          <div class="grp">${next.g} · ${new Date(next.dt).toLocaleDateString('pt-BR',{day:'2-digit',month:'short'})}</div>
          ${getVenue(next)?`<div class="grp">📍 ${getVenue(next).e} · ${getVenue(next).c} ${getVenue(next).f}</div>`:''}
        </div>
        <div class="side r">${next.v}<span class="fl">${next.fv}</span></div>
      </div>`;
  } else {
    title.textContent='🏆 COPA';
    body.innerHTML='<div class="lp-empty">Sem jogos agendados no momento. Peça "atualiza a copa" para o próximo dia.</div>';
  }
}

function tickClock(){
  const now=new Date();
  const el=document.getElementById('clock');
  if(el) el.textContent=now.toLocaleTimeString('pt-BR',{hour12:false});
  // atualiza countdown leve sem redesenhar tudo
  const cd=document.getElementById('cd');
  if(cd){
    const all=allMatches();
    const next=all.find(j=>liveStatus(j)==='fut');
    if(next) cd.textContent=fmtCountdown(new Date(next.dt).getTime()-Date.now());
  }
}


// ═══════════════════════════════════════
//  MODAL DE TIME
// ═══════════════════════════════════════
function horaLocal(utc){
  const now=new Date();
  const local=new Date(now.getTime()+(now.getTimezoneOffset()*60000)+(utc*3600000));
  let h=local.getHours(), m=local.getMinutes();
  return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0');
}
